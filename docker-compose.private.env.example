# Copy this file to .env before starting docker-compose.private.yml.
POSTGRES_DB=mbam
POSTGRES_USER=mbam
POSTGRES_PASSWORD=change_this_local_database_password
POSTGRES_HOST_PORT=5432

KEYCLOAK_HOST_PORT=8180
KEYCLOAK_ADMIN_USERNAME=admin
KEYCLOAK_ADMIN_PASSWORD=change_this_local_admin_password

# Used only when the Rust API is run directly on the host with `cargo run`.
# Keep its database name, user, and password identical to the POSTGRES values above.
# The Compose API overrides this URL and uses the Docker hostname `db` instead.
DATABASE_URL=postgres://mbam:change_this_local_database_password@127.0.0.1:5432/mbam

JWT_ACCESS_SECRET=replace_with_at_least_32_random_characters

# SMTP account used for employee invitations and password resets.
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USERNAME=your_smtp_username
SMTP_PASSWORD=your_smtp_password
SMTP_FROM_EMAIL=no-reply@example.com
SMTP_FROM_NAME=Mbam
