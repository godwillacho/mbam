# Copy this file to .env before starting docker-compose.private.yml.
POSTGRES_DB=mbam
POSTGRES_USER=mbam
POSTGRES_PASSWORD=change_this_local_database_password

JWT_ACCESS_SECRET=replace_with_at_least_32_random_characters
JWT_REFRESH_SECRET=replace_with_another_32_character_random_secret

# SMTP account used for employee invitations and password resets.
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USERNAME=your_smtp_username
SMTP_PASSWORD=your_smtp_password
SMTP_FROM_EMAIL=no-reply@example.com
SMTP_FROM_NAME=Mbam
