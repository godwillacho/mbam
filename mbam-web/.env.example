# Cloud API used for authentication, refresh, and synchronization.
# Leave empty for local Vite development or when the deployed web server
# proxies /api to Mbam API.
# For separate web/API domains, use the public API origin, for example:
# VITE_API_BASE_URL=https://api.example.com
VITE_API_BASE_URL=

# Authentication now uses Keycloak exclusively in the browser.
VITE_AUTH_PROVIDER=keycloak
VITE_KEYCLOAK_URL=http://localhost:8180
VITE_KEYCLOAK_REALM=mbam
VITE_KEYCLOAK_CLIENT_ID=mbam-web

# Base64-encoded DER SubjectPublicKeyInfo for the ES256 offline-grant key.
# Generate from the matching server private key with:
# openssl ec -in offline-private.pem -pubout -outform DER | base64
VITE_OFFLINE_GRANT_PUBLIC_KEY_SPKI=

# Optional browser error reporting. Leave VITE_SENTRY_DSN empty to disable.
# Browser logs are sanitized before console output, offline buffering, or Sentry.
VITE_SENTRY_DSN=
VITE_SENTRY_RELEASE=
VITE_SENTRY_TRACES_SAMPLE_RATE=0
