# Runtime mode used by logs and deployment checks.
APP_ENV=development

# Structured logging. Files rotate daily under LOG_DIRECTORY.
# LOG_JSON defaults to true in production and false otherwise.
RUST_LOG=mbam_api=debug,tower_http=info
LOG_DIRECTORY=logs
LOG_JSON=false

# Optional Sentry error reporting and tracing. Leave SENTRY_DSN empty to disable.
SENTRY_DSN=
SENTRY_RELEASE=
SENTRY_TRACES_SAMPLE_RATE=0

# Socket address for the Axum HTTP server.
API_HOST=127.0.0.1
API_PORT=8080

# PostgreSQL connection string used when running `cargo run` on the host while
# PostgreSQL runs through docker-compose.private.yml. Keep these credentials in
# sync with the root .env POSTGRES_DB, POSTGRES_USER, and POSTGRES_PASSWORD.
# Inside Compose, the API uses the Docker hostname `db` automatically.
DATABASE_URL=postgres://mbam:change_this_local_database_password@127.0.0.1:5432/mbam

# Secret used to sign access tokens. Replace this in every real environment.
JWT_ACCESS_SECRET=replace_me_with_a_long_random_secret_at_least_32_chars

# Secret used to sign refresh tokens. Replace this in every real environment.
JWT_REFRESH_SECRET=replace_me_with_another_long_random_secret_at_least_32_chars

# Token lifetimes in minutes and days.
ACCESS_TOKEN_MINUTES=15
REFRESH_TOKEN_DAYS=30

# Optional ES256 private key used to sign offline grants.
# Store PEM newlines as \n in environment-variable based deployments.
OFFLINE_GRANT_PRIVATE_KEY_PEM=
OFFLINE_GRANT_DAYS=7

# CORS origin for the React frontend during local development.
WEB_ORIGIN=http://localhost:5173

# OAuth providers for owner signup/login.
GOOGLE_OAUTH_CLIENT_ID=replace_me
GOOGLE_OAUTH_CLIENT_SECRET=replace_me
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:8080/api/v1/auth/oauth/google/callback
MICROSOFT_OAUTH_CLIENT_ID=replace_me
MICROSOFT_OAUTH_CLIENT_SECRET=replace_me
MICROSOFT_OAUTH_REDIRECT_URI=http://localhost:8080/api/v1/auth/oauth/microsoft/callback

# SMTP delivery for invitations and password-reset links.
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USERNAME=replace_me
SMTP_PASSWORD=replace_me
SMTP_FROM_EMAIL=no-reply@example.com
SMTP_FROM_NAME=Mbam
