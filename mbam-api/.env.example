# Runtime mode used by logs and deployment checks.
APP_ENV=development

# Socket address for the Axum HTTP server.
API_HOST=127.0.0.1
API_PORT=8080

# PostgreSQL connection string used by SQLx.
DATABASE_URL=postgres://postgres:postgres@localhost:5432/mbam

# Secret used to sign access tokens. Replace this in every real environment.
JWT_ACCESS_SECRET=replace_me_with_a_long_random_secret

# Secret used to sign refresh tokens. Replace this in every real environment.
JWT_REFRESH_SECRET=replace_me_with_another_long_random_secret

# Token lifetimes in minutes and days.
ACCESS_TOKEN_MINUTES=15
REFRESH_TOKEN_DAYS=30

# CORS origin for the React frontend during local development.
WEB_ORIGIN=http://localhost:5173
