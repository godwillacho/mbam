# Runtime mode used by logs and deployment checks.
APP_ENV=development

# Socket address for the Axum HTTP server.
API_HOST=127.0.0.1
API_PORT=8080

# PostgreSQL connection string for the host-run API.
DATABASE_URL=postgres://mbam:change_this_local_database_password@127.0.0.1:5432/mbam

# Authentication provider. Use legacy during migration, then keycloak.
AUTH_PROVIDER=legacy

# Keycloak resource-server settings used when AUTH_PROVIDER=keycloak.
KEYCLOAK_ISSUER_URL=http://localhost:8180/realms/mbam
KEYCLOAK_CLIENT_ID=mbam-api
KEYCLOAK_CLIENT_SECRET=replace_me
KEYCLOAK_AUDIENCE=mbam-api
KEYCLOAK_ROLE_CLIENT_ID=mbam-api
KEYCLOAK_ALLOW_EMAIL_LINKING=false

# Legacy token secrets remain required during the staged migration because the
# current offline grant and device-context code still depends on them.
JWT_ACCESS_SECRET=replace_me_with_a_long_random_secret_at_least_32_chars
JWT_REFRESH_SECRET=replace_me_with_another_long_random_secret_at_least_32_chars
ACCESS_TOKEN_MINUTES=15
REFRESH_TOKEN_DAYS=30

# Optional ES256 private key used to sign offline grants.
OFFLINE_GRANT_PRIVATE_KEY_PEM=
OFFLINE_GRANT_DAYS=7

# CORS origin for the React frontend during local development.
WEB_ORIGIN=http://localhost:5173

# Legacy OAuth provider settings. Configure identity brokering in Keycloak before
# removing these variables in the final migration phase.
GOOGLE_OAUTH_CLIENT_ID=replace_me
GOOGLE_OAUTH_CLIENT_SECRET=replace_me
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:8080/api/v1/auth/oauth/google/callback
MICROSOFT_OAUTH_CLIENT_ID=replace_me
MICROSOFT_OAUTH_CLIENT_SECRET=replace_me
MICROSOFT_OAUTH_REDIRECT_URI=http://localhost:8080/api/v1/auth/oauth/microsoft/callback

# SMTP delivery for invitations and password-reset links during migration.
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USERNAME=replace_me
SMTP_PASSWORD=replace_me
SMTP_FROM_EMAIL=no-reply@example.com
SMTP_FROM_NAME=Mbam
